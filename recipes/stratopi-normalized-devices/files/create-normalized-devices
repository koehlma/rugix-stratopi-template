#!/bin/bash
#
# Create slot-named symlinks for the two SD cards of a Strato Pi.

set -euo pipefail

SYSFS_PATH="/sys/class/stratopimax"
SYMLINK_DIR="/dev/stratopi"

log() { printf '[strato-normalize] %s\n' "$*" >&2; }
die() { log "ERROR: $*"; exit 1; }

detect_main_mmcblk() {
    local path=/
    [[ -d /run/rugix/mounts/system ]] && path=/run/rugix/mounts/system
    rugix-ctrl utils find-block-device "$path" 2>/dev/null | jq -er '.parent'
}

detect_spare_mmcblk() {
    local main=$1 dev
    for dev in /dev/mmcblk[0-9]; do
        [[ -b $dev && $dev != "$main" ]] || continue
        echo "$dev"
        return 0
    done
    return 1
}

publish_links() {
    local slot=$1 mmcblk=$2 part pn
    ln -sfn "$mmcblk" "$SYMLINK_DIR/sd${slot}"
    shopt -s nullglob
    for part in "${mmcblk}"p*; do
        [[ -b $part ]] || continue
        pn=${part##*p}
        ln -sfn "$part" "$SYMLINK_DIR/sd${slot}${pn}"
    done
    shopt -u nullglob
}

SD_SYSFS="$SYSFS_PATH/sd"
[[ -d $SD_SYSFS ]] || die "missing $SD_SYSFS - Strato Pi sysfs not present?"

# Ensure both SD interfaces are enabled (runtime + persistent config).
for iface in sd_main sd_sec; do
    if [[ "$(tr -d '[:space:]' < "$SD_SYSFS/${iface}_enabled")" != "1" ]]; then
        log "enabling $iface"
        echo 1 > "$SD_SYSFS/${iface}_enabled"
        sleep 1
    fi
    if [[ "$(tr -d '[:space:]' < "$SD_SYSFS/${iface}_enabled_config")" != "1" ]]; then
        echo 1 > "$SD_SYSFS/${iface}_enabled_config"
    fi
done

routing=$(tr -d '[:space:]' < "$SD_SYSFS/sd_main_routing")
case "$routing" in
    A) main_slot=a; spare_slot=b ;;
    B) main_slot=b; spare_slot=a ;;
    *) die "unexpected sd_main_routing value: '$routing'" ;;
esac

main_mmcblk=$(detect_main_mmcblk) || die "unable to determine main mmcblk device"

# Remove stale symlinks before (re-)publishing.
rm -rf "$SYMLINK_DIR"
mkdir -p "$SYMLINK_DIR"
publish_links "$main_slot" "$main_mmcblk"

if spare_mmcblk=$(detect_spare_mmcblk "$main_mmcblk"); then
    publish_links "$spare_slot" "$spare_mmcblk"
else
    log "no spare SD card visible; only sd${main_slot}* published"
fi
